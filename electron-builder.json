{
    "appId": "com.vera.cowork",
    "productName": "Vera Cowork",
    "files": [
        "dist-electron",
        "dist-react",
        "node_modules/@letta-ai/letta-code/**/*",
        "node_modules/ws/**/*"
    ],
    "extraResources": [
        "dist-electron/preload.cjs"
    ],
    "asarUnpack": [
        "node_modules/@letta-ai/letta-code-sdk/**/*",
        "node_modules/@letta-ai/letta-code/**/*",
        "node_modules/@letta-ai/letta-code/**/*",
        "node_modules/ws/**/*"
    ],
    "mac": {
        "target": "dmg",
        "icon": "assets/vera-icon.png"
    },
    "linux": {
        "target": "AppImage",
        "category": "Utility",
        "icon": "assets/vera-icon.png"
    },
    "win": {
        "target": [
            "portable"
        ],
        "icon": "assets/vera-icon.png"
    }
}
