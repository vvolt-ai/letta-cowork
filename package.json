{
	"name": "vera-cowork",
	"author": {
		"name": "Bhavesh Prajapati",
		"email": "your-email@example.com"
	},
	"private": true,
	"version": "0.4.0",
	"type": "module",
	"main": "dist-electron/main.js",
	"scripts": {
		"letta": "which letta",
		"rebuild": "npx electron-rebuild -f",
		"dev": "concurrently -k --kill-others-on-fail \"bun run dev:react\" \"bun run dev:electron\"",
		"dev:react": "vite",
		"dev:electron": "bun run transpile:electron && cross-env NODE_ENV=development electron .",
		"build": "tsc -b && vite build",
		"lint": "eslint .",
		"preview": "vite preview",
		"transpile:electron": "tsc --project src/electron/tsconfig.json",
		"dist:mac-arm64": "bun run transpile:electron && bun run build && electron-builder --mac --arm64",
		"dist:mac-x64": "bun run transpile:electron && bun run build && electron-builder --mac --x64",
		"dist:win": "bun run transpile:electron && bun run build && electron-builder --win --x64",
		"dist:linux": "bun run transpile:electron && bun run build && electron-builder --linux deb tar.xz"
	},
	"dependencies": {
		"@letta-ai/letta-code-sdk": "^0.1.14",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@slack/bolt": "^4.6.0",
		"@tailwindcss/vite": "^4.2.2",
		"@whiskeysockets/baileys": "^7.0.0-rc.9",
		"discord.js": "^14.25.1",
		"dotenv": "^17.3.1",
		"electron-store": "^11.0.2",
		"express": "^5.2.1",
		"highlight.js": "^11.11.1",
		"os-utils": "^0.0.14",
		"pino": "^10.3.1",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"rehype-highlight": "^7.0.2",
		"rehype-raw": "^7.0.0",
		"remark-gfm": "^4.0.1",
		"tailwindcss": "^4.2.2",
		"vite-tsconfig-paths": "^6.1.1",
		"ws": "^8.20.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/express": "^5.0.6",
		"@types/os-utils": "^0.0.4",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^40.8.3",
		"electron-builder": "^26.8.1",
		"eslint": "^10.1.0",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"globals": "^17.4.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.3.1"
	}
}